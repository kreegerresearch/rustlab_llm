# Script:  pe_matrix.r
# System:  Sinusoidal positional encoding for a transformer's token stream
# Concept: Build the full T x d_model PE matrix and visualise its banded structure
# Equations:
#   PE(t, 2k)   = sin(t / 10000^(2k / d_model))
#   PE(t, 2k+1) = cos(t / 10000^(2k / d_model))
# Units:   positions (integer t), dimensions (integer i), encoding values dimensionless

# === Configuration ===
T = 64;
d_model = 32;

# === Build the PE matrix (loop form — mirrors the textbook formula cell by cell) ===
PE = zeros(T, d_model);
for t = 1:T
  for i = 1:d_model
    pair_idx = floor((i - 1) / 2);
    div = 10000.0 ^ (2.0 * pair_idx / d_model);
    angle = t / div;
    if mod(i - 1, 2) == 0
      PE(t, i) = sin(angle);
    else
      PE(t, i) = cos(angle);
    end
  end
end

# === Build the PE matrix (vectorized form — every cell is independent) ===
# `mod(I_grid - 1, 2)` is 0 on even columns and 1 on odd, so `1 - mod(...)`
# is the even-column mask without needing matrix-vs-scalar comparison.
[I_grid, T_grid] = meshgrid(1:d_model, 1:T);
pair_idx = floor((I_grid - 1) / 2);
angles   = T_grid ./ (10000.0 .^ (2.0 * pair_idx / d_model));
even_col = 1 - mod(I_grid - 1, 2);
PE_vec   = even_col .* sin(angles) + (1 - even_col) .* cos(angles);

max_diff = max(reshape(abs(PE - PE_vec), 1, T * d_model));
print("Max |loop - vectorized| =", max_diff);

# === Sanity prints ===
print("PE shape:", size(PE));
print("PE(1, 1)  (sin(1)):     ", PE(1, 1));
print("PE(1, 2)  (cos(1)):     ", PE(1, 2));
print("PE(64, 1) (sin(64)):    ", PE(64, 1));
print("PE(t, end) ~= cos(0)=1: ", PE(1, d_model), PE(64, d_model));

# === Heatmap ===
figure()
imagesc(PE, "viridis")
title("Sinusoidal Positional Encoding (T=64, d=32)")
xlabel("Embedding dimension")
ylabel("Position t")
savefig("pe_matrix.svg")
