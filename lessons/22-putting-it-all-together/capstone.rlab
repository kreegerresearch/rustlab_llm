# Script:  capstone.rlab
# System:  End-to-end mini-LM on the periodic corpus
#          "the cat sat on the mat " (repeated 4 times = 92 chars).
# Concept: Composes every prior lesson:
#            Lesson 01 — chars -> integer tokens
#            Lesson 03 — cross-entropy training objective
#            Lesson 16 — AdamW
#            Lesson 17 — warmup + cosine LR schedule
#            Lesson 18 — embedding + LM head bigram-style training loop
#            Lesson 19 — BPE merges, word-level tokens
#            Lesson 20 — perplexity per checkpoint
#            Lesson 21 — autoregressive loop, greedy / temperature /
#                         top-K / top-P sampling
# Equations:
#   h_t        = E(x_t, :)
#   p_t        = softmax(h_t * W)
#   L          = -mean_t log p_t(x_{t+1})
#   PPL        = exp(L)
#   AdamW step on (E, W) with eta_t from the schedule.
# Units:   parameters dimensionless; loss in nats; PPL dimensionless.

# === 1. Corpus + character tokenisation (Lesson 01) ===
# 10 unique chars in "the cat sat on the mat ": space, a, c, e, h, m, n, o, s, t.
function id = char_id(c)
  if c == " "
    id = 1;
  elseif c == "a"
    id = 2;
  elseif c == "c"
    id = 3;
  elseif c == "e"
    id = 4;
  elseif c == "h"
    id = 5;
  elseif c == "m"
    id = 6;
  elseif c == "n"
    id = 7;
  elseif c == "o"
    id = 8;
  elseif c == "s"
    id = 9;
  elseif c == "t"
    id = 10;
  end
end
char_names = {" ", "a", "c", "e", "h", "m", "n", "o", "s", "t"};
n_base_chars = 10;

% Build the periodic corpus: phrase = "the cat sat on the mat " (23 chars),
% repeated 4 times = 92 chars.
phrase = "the cat sat on the mat ";
n_reps = 4;
L_total = length(phrase) * n_reps;
char_seq = zeros(L_total);
k = 1;
for r = 1:n_reps
  for i = 1:length(phrase)
    char_seq(k) = char_id(phrase(i));
    k = k + 1;
  end
end
print("=== Corpus ===");
print("phrase:", phrase, " (length", length(phrase), ")");
print("repeated", n_reps, "times: total chars =", L_total);
print("first 24 char ids:", char_seq(1:24));

# === 2. BPE tokenisation (Lesson 19) ===
# Same merge algorithm as lessons/19-byte-pair-encoding/bpe_train.rlab,
# inlined for self-containment.
function r = bpe_step(seq, vocab_size)
  V = vocab_size;
  L = length(seq);
  counts = zeros(V, V);
  for i = 1:(L - 1)
    a = seq(i); b = seq(i + 1);
    counts(a, b) = counts(a, b) + 1;
  end
  flat = reshape(counts, 1, V * V);
  idx = argmax(flat);
  best_a = mod(idx - 1, V) + 1;
  best_b = floor((idx - 1) / V) + 1;
  best_c = counts(best_a, best_b);
  new_id = V + 1;
  new_seq = zeros(L);
  k = 1; i = 1;
  while i <= L
    if i < L && seq(i) == best_a && seq(i + 1) == best_b
      new_seq(k) = new_id;
      k = k + 1; i = i + 2;
    else
      new_seq(k) = seq(i);
      k = k + 1; i = i + 1;
    end
  end
  trimmed = new_seq(1:(k - 1));
  r = struct("seq", trimmed, "a", best_a, "b", best_b, "count", best_c, "vocab", new_id);
end

# Run 8 merges.  After merge 8 we expect tokens close to " the", " cat",
# " sat", " on", " mat" — word-level structure.
n_merges = 8;
cur_seq = char_seq;
cur_vocab = n_base_chars;
print("");
print("=== BPE training (Lesson 19) ===");
for m = 1:n_merges
  step = bpe_step(cur_seq, cur_vocab);
  print("Merge", m, " pair (", step.a, ",", step.b, ") count =", step.count, "  new_id =", step.vocab, " seq len =", length(step.seq));
  cur_seq = step.seq;
  cur_vocab = step.vocab;
end
tokens = cur_seq;
vocab = cur_vocab;
n_tokens = length(tokens);
print("After", n_merges, "merges: vocab =", vocab, "  seq length =", n_tokens);

# === 3. Train / val split (Lesson 18, Lesson 20) ===
# Keep the last 20% as validation; train on the first 80%.
n_pairs_total = n_tokens - 1;
n_train_pairs = floor(0.8 * n_pairs_total);
n_val_pairs   = n_pairs_total - n_train_pairs;
val_start = n_train_pairs + 1;
print("");
print("=== Train / val split ===");
print("train pairs:", n_train_pairs, "  val pairs:", n_val_pairs);

# === 4. Model: embedding + LM head (Lesson 14 architecture, Lesson 18 training)
# Trainable parameters: E (vocab x d_emb), W (d_emb x vocab).  The full Lesson
# 14 stack (token + positional encoding + transformer block + final LN) is
# wired up in full_architecture_forward.rlab; here we train the
# embedding/head surrogate so the loop is fast enough to run inline. ===
seed(22);
d_emb = 6;
E = randn(vocab, d_emb) * 0.3;
W = randn(d_emb, vocab) * 0.3;
print("");
print("=== Model ===");
print("vocab:", vocab, "  d_emb:", d_emb, "  parameters:", vocab * d_emb + d_emb * vocab);

# === 5. Training (Lesson 18) ===
# Forward, backward, AdamW (Lesson 16), warmup+cosine schedule (Lesson 17).
function [dE_pair, dW_pair, L_pair] = step_grad(curr, nxt, E, W, vocab, d_emb)
  h = E(curr, :);
  p = softmax(h * W);
  L_pair = -log(p(nxt));
  e_y = zeros(vocab); e_y(nxt) = 1.0;
  dlogits = p - e_y;
  dW_pair = h' * dlogits;
  dh = dlogits * W';
  dE_pair = zeros(vocab, d_emb);
  for k = 1:d_emb
    dE_pair(curr, k) = dh(k);
  end
end

function L = mean_loss(start_idx, n_pairs, tokens, E, W)
  L = 0.0;
  for k = 0:(n_pairs - 1)
    curr = tokens(start_idx + k);
    nxt  = tokens(start_idx + k + 1);
    h = E(curr, :);
    pv = softmax(h * W);
    L = L + (-log(pv(nxt)));
  end
  L = L / n_pairs;
end

# Hyperparameters
n_train = 800;
b1 = 0.9; b2 = 0.999; eps_a = 1e-8;
eta_max = 0.10; eta_min = 0.010; T_w = 80;

# AdamW state
m_E = zeros(vocab, d_emb); v_E = zeros(vocab, d_emb);
m_W = zeros(d_emb, vocab); v_W = zeros(d_emb, vocab);

# Diagnostic buffers
loss_train = zeros(n_train + 1);
loss_val   = zeros(n_train + 1);
ppl_train  = zeros(n_train + 1);
ppl_val    = zeros(n_train + 1);
gnorm      = zeros(n_train + 1);
lr_curve   = zeros(n_train + 1);
loss_train(1) = mean_loss(1, n_train_pairs, tokens, E, W);
loss_val(1)   = mean_loss(val_start, n_val_pairs, tokens, E, W);
ppl_train(1)  = exp(loss_train(1));
ppl_val(1)    = exp(loss_val(1));
print("");
print("=== Training (Lesson 18) ===");
print("Initial train loss:", loss_train(1), "  PPL:", ppl_train(1), "  (log(vocab) =", log(vocab), " is uniform baseline)");

# Checkpoint snapshots — keep one (E, W) pair per checkpoint step.
E_ck0 = E; W_ck0 = W;

for t = 1:n_train
  # LR schedule (Lesson 17)
  if t <= T_w
    eta_t = eta_max * (t / T_w);
  else
    prog = (t - T_w) / (n_train - T_w);
    eta_t = eta_min + 0.5 * (eta_max - eta_min) * (1 + cos(pi * prog));
  end
  lr_curve(t + 1) = eta_t;

  # Full-batch gradient over the training pairs
  dE_sum = zeros(vocab, d_emb);
  dW_sum = zeros(d_emb, vocab);
  for k = 0:(n_train_pairs - 1)
    curr = tokens(1 + k); nxt = tokens(2 + k);
    [dE_k, dW_k, L_k] = step_grad(curr, nxt, E, W, vocab, d_emb);
    dE_sum = dE_sum + dE_k;
    dW_sum = dW_sum + dW_k;
  end
  dE = dE_sum / n_train_pairs;
  dW = dW_sum / n_train_pairs;

  # Gradient norm
  gn_sq = sum(reshape(dE .^ 2, 1, vocab * d_emb)) + sum(reshape(dW .^ 2, 1, d_emb * vocab));
  gnorm(t + 1) = sqrt(gn_sq);

  # AdamW updates
  m_E = b1 * m_E + (1 - b1) * dE;
  v_E = b2 * v_E + (1 - b2) * (dE .^ 2);
  E = E - eta_t * ((m_E / (1 - b1 ^ t)) ./ (sqrt(v_E / (1 - b2 ^ t)) + eps_a));
  m_W = b1 * m_W + (1 - b1) * dW;
  v_W = b2 * v_W + (1 - b2) * (dW .^ 2);
  W = W - eta_t * ((m_W / (1 - b1 ^ t)) ./ (sqrt(v_W / (1 - b2 ^ t)) + eps_a));

  loss_train(t + 1) = mean_loss(1, n_train_pairs, tokens, E, W);
  loss_val(t + 1)   = mean_loss(val_start, n_val_pairs, tokens, E, W);
  ppl_train(t + 1)  = exp(loss_train(t + 1));
  ppl_val(t + 1)    = exp(loss_val(t + 1));

  # Snapshot at checkpoint steps for the generation gallery below.
  if t == 100
    E_ck1 = E; W_ck1 = W;
  elseif t == 300
    E_ck2 = E; W_ck2 = W;
  elseif t == 800
    E_ck3 = E; W_ck3 = W;
  end
end
print("Final train loss:", loss_train(n_train + 1), "  PPL:", ppl_train(n_train + 1));
print("Final val   loss:", loss_val(n_train + 1),   "  PPL:", ppl_val(n_train + 1));

# === 6. Per-token decoder (BPE merge list back to chars) ===
# Re-run BPE once more to record each merged-token's two parents.  Then a
# token-id sequence decodes back to chars by recursively walking from each
# id down to base chars.  (Storing strings directly in a cell array hits
# a rustlab limitation; the parent-pointer form sidesteps it.)
function [left_parent, right_parent] = compute_merge_table(char_seq, n_base, n_merges)
  total = n_base + n_merges;
  left_parent  = zeros(total);     % 0 means terminal (base char)
  right_parent = zeros(total);
  cur_seq = char_seq;
  cur_vocab = n_base;
  for m = 1:n_merges
    step = bpe_step(cur_seq, cur_vocab);
    new_id = step.vocab;
    left_parent(new_id)  = step.a;
    right_parent(new_id) = step.b;
    cur_seq = step.seq;
    cur_vocab = new_id;
  end
end

# Recursively expand one token id into its character-ID sequence.
# rustlab 0.3.4+: length() accepts a scalar (returns 1) and [L, R] handles
# scalar-vector concat transparently, so the terminal case can return the
# bare id and the caller's `length(chars_i)` still works.
function chars_out = expand_token(id, left_parent, right_parent)
  if left_parent(id) == 0
    chars_out = id;
  else
    L = expand_token(left_parent(id),  left_parent, right_parent);
    R = expand_token(right_parent(id), left_parent, right_parent);
    chars_out = [L, R];
  end
end

# Render a token id sequence by expanding each id to base chars, then
# concatenating the char_names lookup into a single string.
function s = decode_seq(tok_seq, left_parent, right_parent, char_names)
  s = "";
  for i = 1:length(tok_seq)
    chars_i = expand_token(tok_seq(i), left_parent, right_parent);
    for j = 1:length(chars_i)
      s = s + char_names(chars_i(j));
    end
  end
end

# === 7. Generation (Lesson 21) ===
function p = next_dist(x_curr, E, W)
  p = softmax(E(x_curr, :) * W);
end

function seq = greedy_gen(x0, n_new, E, W)
  seq = zeros(n_new + 1);
  seq(1) = x0;
  for t = 1:n_new
    seq(t + 1) = argmax(next_dist(seq(t), E, W));
  end
end

function tok = sample_categorical(p)
  # Inverse-CDF sampling: walk the cumulative distribution until we cross r.
  c = cumsum(p);
  r = rand();
  N = length(p);
  i = 1;
  while i < N && c(i) < r
    i = i + 1;
  end
  tok = i;
end

function seq = temp_gen(x0, n_new, E, W, T_temp)
  seq = zeros(n_new + 1);
  seq(1) = x0;
  for t = 1:n_new
    logits = E(seq(t), :) * W;
    p = softmax(logits / T_temp);
    seq(t + 1) = sample_categorical(p);
  end
end

function q = topk_mass(p, K_top)
  K = length(p);
  [s_asc, idx_asc] = sort(p);
  desc_idx = idx_asc(K:-1:1);
  keep = desc_idx(1:K_top);
  q = zeros(K);
  mass = 0.0;
  for j = 1:K_top
    mass = mass + p(keep(j));
  end
  for j = 1:K_top
    q(keep(j)) = p(keep(j)) / mass;
  end
end

function seq = topk_gen(x0, n_new, E, W, K_top, T_temp)
  seq = zeros(n_new + 1);
  seq(1) = x0;
  for t = 1:n_new
    p = softmax(E(seq(t), :) * W / T_temp);
    q = topk_mass(p, K_top);
    seq(t + 1) = sample_categorical(q);
  end
end

function q = topp_mass(p, P)
  K = length(p);
  [s_asc, idx_asc] = sort(p);
  desc_idx = idx_asc(K:-1:1);
  desc_p   = s_asc(K:-1:1);
  c = cumsum(desc_p);
  # Walk forward to the first index where the cumulative mass clears P.
  # `while ... < P` exits naturally — no `break` keyword needed.
  j = 1;
  while j < K && c(j) < P
    j = j + 1;
  end
  n_keep = j;
  q = zeros(K);
  mass = c(n_keep);
  for j = 1:n_keep
    q(desc_idx(j)) = desc_p(j) / mass;
  end
end

function seq = topp_gen(x0, n_new, E, W, P_top, T_temp)
  seq = zeros(n_new + 1);
  seq(1) = x0;
  for t = 1:n_new
    p = softmax(E(seq(t), :) * W / T_temp);
    q = topp_mass(p, P_top);
    seq(t + 1) = sample_categorical(q);
  end
end

# === 8. Checkpoint gallery ===
[lp, rp] = compute_merge_table(char_seq, n_base_chars, n_merges);

# Pick a prompt token that has a unique starting character — id 1 is " ".
prompt_id = 1;
n_gen = 12;

print("");
print("=== Checkpoint gallery (12 tokens from prompt 'space') ===");
print("step   0 greedy : ", decode_seq(greedy_gen(prompt_id, n_gen, E_ck0, W_ck0), lp, rp, char_names));
print("step 100 greedy : ", decode_seq(greedy_gen(prompt_id, n_gen, E_ck1, W_ck1), lp, rp, char_names));
print("step 300 greedy : ", decode_seq(greedy_gen(prompt_id, n_gen, E_ck2, W_ck2), lp, rp, char_names));
print("step 800 greedy : ", decode_seq(greedy_gen(prompt_id, n_gen, E_ck3, W_ck3), lp, rp, char_names));
seed(101);
print("step 800 T=0.7  : ", decode_seq(temp_gen(prompt_id, n_gen, E_ck3, W_ck3, 0.7), lp, rp, char_names));
print("step 800 T=1.0  : ", decode_seq(temp_gen(prompt_id, n_gen, E_ck3, W_ck3, 1.0), lp, rp, char_names));
print("step 800 K=3    : ", decode_seq(topk_gen(prompt_id, n_gen, E_ck3, W_ck3, 3, 1.0), lp, rp, char_names));
print("step 800 P=0.9  : ", decode_seq(topp_gen(prompt_id, n_gen, E_ck3, W_ck3, 0.9, 1.0), lp, rp, char_names));

# === 9. Diagnostic plots ===
steps_axis = 0:n_train;
figure()
subplot(2, 2, 1)
plot(steps_axis, loss_train, "color", "red",  "label", "train")
hold("on")
plot(steps_axis, loss_val,   "color", "blue", "label", "val")
hold("off")
title("Train vs val loss (nats)")
xlabel("step"); ylabel("L"); legend("train", "val")

subplot(2, 2, 2)
plot(steps_axis, ppl_train, "color", "red", "label", "train")
hold("on")
plot(steps_axis, ppl_val,   "color", "blue", "label", "val")
hold("off")
title("Train vs val PPL")
xlabel("step"); ylabel("PPL"); legend("train", "val")

subplot(2, 2, 3)
plot(steps_axis, log10(gnorm + 1e-12), "color", "green")
title("log10 || grad || over training")
xlabel("step"); ylabel("log10 ||grad||")

subplot(2, 2, 4)
plot(steps_axis, lr_curve, "color", "purple")
title("Learning-rate schedule (warmup + cosine)")
xlabel("step"); ylabel("eta")
savefig("capstone.svg")
print("");
print("Saved capstone.svg");
