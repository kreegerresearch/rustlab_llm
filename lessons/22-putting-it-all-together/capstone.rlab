# Script:  capstone.rlab
# System:  End-to-end mini-GPT on the periodic corpus
#          "the cat sat on the mat " (repeated 4 times = 92 chars).
# Concept: Composes every prior lesson:
#            Lesson 01 — chars -> integer tokens
#            Lesson 03 — cross-entropy training objective
#            Lesson 08-13 — single-block transformer forward (attention,
#                            LN, FFN, residuals)
#            Lesson 14 — token + sinusoidal PE + block + LM head wiring
#            Lesson 15 — chain rule per layer
#            Lesson 16 — AdamW
#            Lesson 17 — warmup + cosine LR schedule
#            Lesson 18 — train / val / log diagnostics
#            Lesson 19 — BPE merges, word-level tokens
#            Lesson 20 — perplexity per checkpoint
#            Lesson 21 — autoregressive loop, sampling strategies
#            Lesson 24 — full transformer backward pass
#          The forward/backward library is copied verbatim from
#          lessons/24-full-backprop-and-fine-tuning/full_backprop.rlab so
#          this script is self-contained per project convention.
# Equations: see notebooks/22-putting-it-all-together.md.
# Units:   parameters dimensionless; loss in nats; PPL dimensionless.

# === 1. Corpus + character tokenisation (Lesson 01) ===
# 10 unique chars in "the cat sat on the mat ": space, a, c, e, h, m, n, o, s, t.
function id = char_id(c)
  if c == " "
    id = 1;
  elseif c == "a"
    id = 2;
  elseif c == "c"
    id = 3;
  elseif c == "e"
    id = 4;
  elseif c == "h"
    id = 5;
  elseif c == "m"
    id = 6;
  elseif c == "n"
    id = 7;
  elseif c == "o"
    id = 8;
  elseif c == "s"
    id = 9;
  elseif c == "t"
    id = 10;
  end
end
char_names = {" ", "a", "c", "e", "h", "m", "n", "o", "s", "t"};
n_base_chars = 10;

phrase = "the cat sat on the mat ";
n_reps = 4;
L_total = length(phrase) * n_reps;
char_seq = zeros(L_total);
k = 1;
for r = 1:n_reps
  for i = 1:length(phrase)
    char_seq(k) = char_id(phrase(i));
    k = k + 1;
  end
end
print("=== Corpus ===");
print("phrase:", phrase, " (length", length(phrase), ")");
print("repeated", n_reps, "times: total chars =", L_total);

# === 2. BPE tokenisation (Lesson 19) ===
function r = bpe_step(seq, vocab_size)
  V = vocab_size;
  L = length(seq);
  counts = zeros(V, V);
  for i = 1:(L - 1)
    a = seq(i); b = seq(i + 1);
    counts(a, b) = counts(a, b) + 1;
  end
  flat = reshape(counts, 1, V * V);
  idx = argmax(flat);
  best_a = mod(idx - 1, V) + 1;
  best_b = floor((idx - 1) / V) + 1;
  best_c = counts(best_a, best_b);
  new_id = V + 1;
  new_seq = zeros(L);
  k = 1; i = 1;
  while i <= L
    if i < L && seq(i) == best_a && seq(i + 1) == best_b
      new_seq(k) = new_id;
      k = k + 1; i = i + 2;
    else
      new_seq(k) = seq(i);
      k = k + 1; i = i + 1;
    end
  end
  trimmed = new_seq(1:(k - 1));
  r = struct("seq", trimmed, "a", best_a, "b", best_b, "count", best_c, "vocab", new_id);
end

n_merges = 8;
cur_seq = char_seq;
cur_vocab = n_base_chars;
print("");
print("=== BPE training (Lesson 19) ===");
for m = 1:n_merges
  step = bpe_step(cur_seq, cur_vocab);
  print("Merge", m, " pair (", step.a, ",", step.b, ") count =", step.count, "  new_id =", step.vocab, " seq len =", length(step.seq));
  cur_seq = step.seq;
  cur_vocab = step.vocab;
end
tokens = cur_seq;
vocab = cur_vocab;
T = length(tokens);
print("After", n_merges, "merges: vocab =", vocab, "  seq length =", T);

# Parent table for decoding token-ids back to char-id sequences.
function [left_parent, right_parent] = compute_merge_table(char_seq, n_base, n_merges)
  total = n_base + n_merges;
  left_parent = zeros(total);
  right_parent = zeros(total);
  cur_seq = char_seq;
  cur_vocab = n_base;
  for m = 1:n_merges
    step = bpe_step(cur_seq, cur_vocab);
    new_id = step.vocab;
    left_parent(new_id) = step.a;
    right_parent(new_id) = step.b;
    cur_seq = step.seq;
    cur_vocab = new_id;
  end
end

function chars_out = expand_token(id, left_parent, right_parent)
  # Wrap the terminal case in [id] so the result is always a 1xN matrix.
  # rustlab 0.3.4 has length(scalar) = 1 but scalar(j) errors as
  # `undefined function`, so the downstream loop over the result needs
  # the 1x1 form, not the bare scalar.
  if left_parent(id) == 0
    chars_out = [id];
  else
    L = expand_token(left_parent(id), left_parent, right_parent);
    R = expand_token(right_parent(id), left_parent, right_parent);
    chars_out = [L, R];
  end
end

function s = decode_seq(tok_seq, left_parent, right_parent, char_names)
  s = "";
  for i = 1:length(tok_seq)
    chars_i = expand_token(tok_seq(i), left_parent, right_parent);
    for j = 1:length(chars_i)
      s = s + char_names(chars_i(j));
    end
  end
end

# === 3. Train on the full sequence (Lesson 18) ===
# The OLD lesson-22 capstone used an 80/20 train/val split.  That made
# sense for the bigram-only model.  Once we use positional embeddings,
# the held-out positions are PE-out-of-distribution from the training
# positions (PE(25) is a different sinusoidal vector than PE(1..24) ever
# saw), so a val PPL spike does not signal overfitting — it just shows
# the model cannot extrapolate to position indices it has never trained
# on.  For the capstone we train on every prediction position.
n_pairs = T - 1;
print("");
print("training pairs (full corpus):", n_pairs);

# === 4. Model: full Lesson-14 architecture, single block, single head ===
seed(22);
d_model = 4;
d_ff = 8;
T_max = T + 16;     # PE table large enough for any generation prefix.

E = randn(vocab, d_model) * 0.3;
PE = zeros(T_max, d_model);
for t = 1:T_max
  for k = 0:(d_model / 2 - 1)
    omega = 10000.0 ^ (-2 * k / d_model);
    PE(t, 2 * k + 1) = sin((t - 1) * omega);
    PE(t, 2 * k + 2) = cos((t - 1) * omega);
  end
end
gamma1 = ones(d_model);   beta1 = zeros(d_model);
gamma2 = ones(d_model);   beta2 = zeros(d_model);
Wq = randn(d_model, d_model) * 0.3;
Wk = randn(d_model, d_model) * 0.3;
Wv = randn(d_model, d_model) * 0.3;
Wo = randn(d_model, d_model) * 0.3;
W1 = randn(d_model, d_ff) * 0.3;  b1f = zeros(d_ff);
W2 = randn(d_ff, d_model) * 0.3;  b2f = zeros(d_model);
W_U = randn(d_model, vocab) * 0.3;
n_params = vocab * d_model + 4 * d_model + 4 * d_model * d_model + 2 * d_model * d_ff + d_ff + d_model + d_model * vocab;
print("");
print("=== Model (single-block transformer) ===");
print("vocab:", vocab, "  d_model:", d_model, "  d_ff:", d_ff, "  params:", n_params);

# === 5. Forward + backward library (copied verbatim from Lesson 24) ===
function [Y, x_norm_M, sigma_v] = layernorm_fwd(X, gamma, beta)
  T = size(X)(1);  d = size(X)(2);  eps = 1e-5;
  Y = zeros(T, d);  x_norm_M = zeros(T, d);  sigma_v = zeros(T);
  for t = 1:T
    x = X(t, :);  mu = mean(x);  var = mean((x - mu) .^ 2);
    sigma = sqrt(var + eps);  xn = (x - mu) / sigma;
    sigma_v(t) = sigma;  x_norm_M(t, :) = xn;
    Y(t, :) = xn .* gamma + beta;
  end
end

function [dX, dgamma, dbeta] = layernorm_bwd(dY, x_norm_M, sigma_v, gamma)
  T = size(dY)(1);  d = size(dY)(2);
  dX = zeros(T, d);  dgamma = zeros(d);  dbeta = zeros(d);
  for t = 1:T
    dgamma = dgamma + dY(t, :) .* x_norm_M(t, :);
    dbeta  = dbeta  + dY(t, :);
  end
  for t = 1:T
    dx_norm = dY(t, :) .* gamma;  xn = x_norm_M(t, :);
    dX(t, :) = (1.0 / sigma_v(t)) * (dx_norm - mean(dx_norm) - xn * mean(dx_norm .* xn));
  end
end

function y = gelu_grad(z)
  c = sqrt(2.0 / pi);  u = c * (z + 0.044715 * z .^ 3);  th = tanh(u);
  du_dz = c * (1.0 + 0.044715 * 3.0 * z .^ 2);  sech2 = 1.0 - th .^ 2;
  y = 0.5 * (1.0 + th) + 0.5 * z .* sech2 .* du_dz;
end

# Mask-aware forward: a `loss_mask` row vector controls which positions
# contribute to L.  For the corpus training pass we use mask = all ones.
# For generation we pass an all-zero mask to suppress loss accumulation
# (we only want the logits).
function [logits, L, cache] = forward(ids, loss_mask, E, PE, gamma1, beta1, gamma2, beta2, ...
                                        Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U)
  T = length(ids);  d_model = size(E)(2);  vocab = size(E)(1);
  H_in = zeros(T, d_model);
  for t = 1:T
    H_in(t, :) = E(ids(t), :) + PE(t, :);
  end
  [H_ln1, x_norm1, sigma1] = layernorm_fwd(H_in, gamma1, beta1);
  Q = H_ln1 * Wq;  K = H_ln1 * Wk;  V = H_ln1 * Wv;
  scale = 1.0 / sqrt(d_model);
  S = (Q * K') * scale;
  for i = 1:T
    for j = (i + 1):T
      S(i, j) = -1e9;
    end
  end
  A = softmax(S);
  attn_out = A * V;  proj = attn_out * Wo;  H_mid = H_in + proj;
  [H_ln2, x_norm2, sigma2] = layernorm_fwd(H_mid, gamma2, beta2);
  pre_gelu = H_ln2 * W1 + repmat(b1f, T, 1);
  hidden = gelu(pre_gelu);
  ffn_out = hidden * W2 + repmat(b2f, T, 1);
  H_out = H_mid + ffn_out;
  logits = H_out * W_U;
  L = 0.0;  total = 0.0;
  for t = 1:(T - 1)
    if loss_mask(t) > 0
      p = softmax(logits(t, :));
      L = L - log(p(ids(t + 1)));
      total = total + 1.0;
    end
  end
  if total > 0
    L = L / total;
  end
  cache = struct("T", T, "H_in", H_in, "H_ln1", H_ln1, "x_norm1", x_norm1, "sigma1", sigma1, ...
                 "Q", Q, "K", K, "V", V, "S", S, "A", A, "attn_out", attn_out, "proj", proj, ...
                 "H_mid", H_mid, "H_ln2", H_ln2, "x_norm2", x_norm2, "sigma2", sigma2, ...
                 "pre_gelu", pre_gelu, "hidden", hidden, "ffn_out", ffn_out, "H_out", H_out, ...
                 "logits", logits, "scale", scale, "total", total);
end

function [dE, dgamma1, dbeta1, dgamma2, dbeta2, ...
          dWq, dWk, dWv, dWo, dW1, db1f, dW2, db2f, dW_U] = ...
    backward(ids, loss_mask, cache, E, gamma1, gamma2, Wq, Wk, Wv, Wo, W1, W2, W_U)
  T = cache.T;  H_ln1 = cache.H_ln1;  x_norm1 = cache.x_norm1;  sigma1 = cache.sigma1;
  Q = cache.Q;  K = cache.K;  V = cache.V;  A = cache.A;
  attn_out = cache.attn_out;  H_mid = cache.H_mid;
  H_ln2 = cache.H_ln2;  x_norm2 = cache.x_norm2;  sigma2 = cache.sigma2;
  pre_gelu = cache.pre_gelu;  hidden = cache.hidden;  H_out = cache.H_out;
  logits = cache.logits;  scale = cache.scale;  total = cache.total;
  d_model = size(E)(2);  vocab = size(E)(1);

  dlogits = zeros(T, vocab);
  if total > 0
    for t = 1:(T - 1)
      if loss_mask(t) > 0
        p = softmax(logits(t, :));
        e_y = zeros(vocab); e_y(ids(t + 1)) = 1.0;
        dlogits(t, :) = (p - e_y) / total;
      end
    end
  end
  dW_U = H_out' * dlogits;
  dH_out = dlogits * W_U';
  d_ffn_out = dH_out;  dH_mid = dH_out;
  dhidden = d_ffn_out * W2';
  dW2 = hidden' * d_ffn_out;
  db2f = zeros(d_model);
  for t = 1:T
    db2f = db2f + d_ffn_out(t, :);
  end
  dpre_gelu = dhidden .* gelu_grad(pre_gelu);
  dH_ln2 = dpre_gelu * W1';
  dW1 = H_ln2' * dpre_gelu;
  d_ff = size(W1)(2);
  db1f = zeros(d_ff);
  for t = 1:T
    db1f = db1f + dpre_gelu(t, :);
  end
  [dH_mid_from_ln, dgamma2, dbeta2] = layernorm_bwd(dH_ln2, x_norm2, sigma2, gamma2);
  dH_mid = dH_mid + dH_mid_from_ln;
  dH_in = dH_mid;  dproj = dH_mid;
  dattn_out = dproj * Wo';  dWo = attn_out' * dproj;
  dA = dattn_out * V';  dV = A' * dattn_out;
  dS = zeros(T, T);
  for t = 1:T
    a_row = A(t, :);  da_row = dA(t, :);
    dS(t, :) = a_row .* (da_row - sum(a_row .* da_row));
  end
  dQ = (dS * K) * scale;  dK = (dS' * Q) * scale;
  dH_ln1 = dQ * Wq' + dK * Wk' + dV * Wv';
  dWq = H_ln1' * dQ;  dWk = H_ln1' * dK;  dWv = H_ln1' * dV;
  [dH_in_from_ln, dgamma1, dbeta1] = layernorm_bwd(dH_ln1, x_norm1, sigma1, gamma1);
  dH_in = dH_in + dH_in_from_ln;
  dE = zeros(vocab, d_model);
  for t = 1:T
    tok = ids(t);
    dE(tok, :) = dE(tok, :) + dH_in(t, :);
  end
end

# === 6. Mean-loss / PPL helper.  Reuses forward() with full mask. ===
function L = mean_loss(start_idx, n_pairs, ids, E, PE, gamma1, beta1, gamma2, beta2, ...
                        Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U)
  T_full = start_idx + n_pairs;
  ids_slice = ids(1:T_full);
  T_slice = length(ids_slice);
  mask = zeros(T_slice - 1);
  for t = start_idx:(T_slice - 1)
    mask(t) = 1;
  end
  [lo, L, ca] = forward(ids_slice, mask, E, PE, gamma1, beta1, gamma2, beta2, ...
                         Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
end

# === 7. Training (Lessons 16, 17, 18, 24) ===
m_E = zeros(vocab, d_model);     v_E = zeros(vocab, d_model);
m_g1 = zeros(d_model);           v_g1 = zeros(d_model);
m_b1 = zeros(d_model);           v_b1 = zeros(d_model);
m_g2 = zeros(d_model);           v_g2 = zeros(d_model);
m_b2 = zeros(d_model);           v_b2 = zeros(d_model);
m_Wq = zeros(d_model, d_model);  v_Wq = zeros(d_model, d_model);
m_Wk = zeros(d_model, d_model);  v_Wk = zeros(d_model, d_model);
m_Wv = zeros(d_model, d_model);  v_Wv = zeros(d_model, d_model);
m_Wo = zeros(d_model, d_model);  v_Wo = zeros(d_model, d_model);
m_W1 = zeros(d_model, d_ff);     v_W1 = zeros(d_model, d_ff);
m_b1f = zeros(d_ff);             v_b1f = zeros(d_ff);
m_W2 = zeros(d_ff, d_model);     v_W2 = zeros(d_ff, d_model);
m_b2f = zeros(d_model);          v_b2f = zeros(d_model);
m_WU = zeros(d_model, vocab);    v_WU = zeros(d_model, vocab);

bet1 = 0.9; bet2 = 0.999; eps_a = 1e-8;
n_train = 600;
eta_max = 0.05; eta_min = 0.005; T_w = 60;

# Full-sequence training mask — every prediction position contributes.
mask_train = ones(T - 1);

loss_curve = zeros(n_train + 1);
ppl_curve  = zeros(n_train + 1);
gnorm      = zeros(n_train + 1);
lr_curve   = zeros(n_train + 1);
loss_curve(1) = mean_loss(1, n_pairs, tokens, E, PE, gamma1, beta1, gamma2, beta2, ...
                            Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
ppl_curve(1) = exp(loss_curve(1));
print("");
print("=== Training (full transformer, 600 steps) ===");
print("Initial L =", loss_curve(1), "  PPL =", ppl_curve(1));
print("(log(vocab) =", log(vocab), "is the uniform baseline.)");

# Checkpoint storage — copy parameters at step 0, 100, 300, and 600.
E_ck0 = E; gamma1_ck0 = gamma1; beta1_ck0 = beta1; gamma2_ck0 = gamma2; beta2_ck0 = beta2;
Wq_ck0 = Wq; Wk_ck0 = Wk; Wv_ck0 = Wv; Wo_ck0 = Wo;
W1_ck0 = W1; b1f_ck0 = b1f; W2_ck0 = W2; b2f_ck0 = b2f; W_U_ck0 = W_U;

for step = 1:n_train
  if step <= T_w
    eta_t = eta_max * (step / T_w);
  else
    prog = (step - T_w) / (n_train - T_w);
    eta_t = eta_min + 0.5 * (eta_max - eta_min) * (1 + cos(pi * prog));
  end
  lr_curve(step + 1) = eta_t;

  [lo, L, ca] = forward(tokens, mask_train, E, PE, gamma1, beta1, gamma2, beta2, ...
                         Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
  [dE, dg1, db1, dg2, db2, dWq, dWk, dWv, dWo, dW1, db1f_g, dW2, db2f_g, dW_U] = ...
      backward(tokens, mask_train, ca, E, gamma1, gamma2, Wq, Wk, Wv, Wo, W1, W2, W_U);

  # Gradient norm (sum of all parameter gradients squared, then sqrt).
  gn_sq = sum(reshape(dE .^ 2, 1, vocab * d_model)) + ...
          sum(dg1 .^ 2) + sum(db1 .^ 2) + sum(dg2 .^ 2) + sum(db2 .^ 2) + ...
          sum(reshape(dWq .^ 2, 1, d_model * d_model)) + ...
          sum(reshape(dWk .^ 2, 1, d_model * d_model)) + ...
          sum(reshape(dWv .^ 2, 1, d_model * d_model)) + ...
          sum(reshape(dWo .^ 2, 1, d_model * d_model)) + ...
          sum(reshape(dW1 .^ 2, 1, d_model * d_ff)) + sum(db1f_g .^ 2) + ...
          sum(reshape(dW2 .^ 2, 1, d_ff * d_model)) + sum(db2f_g .^ 2) + ...
          sum(reshape(dW_U .^ 2, 1, d_model * vocab));
  gnorm(step + 1) = sqrt(gn_sq);

  m_E = bet1 * m_E + (1 - bet1) * dE;
  v_E = bet2 * v_E + (1 - bet2) * (dE .^ 2);
  E = E - eta_t * ((m_E / (1 - bet1 ^ step)) ./ (sqrt(v_E / (1 - bet2 ^ step)) + eps_a));
  m_g1 = bet1 * m_g1 + (1 - bet1) * dg1;  v_g1 = bet2 * v_g1 + (1 - bet2) * (dg1 .^ 2);
  gamma1 = gamma1 - eta_t * ((m_g1 / (1 - bet1 ^ step)) ./ (sqrt(v_g1 / (1 - bet2 ^ step)) + eps_a));
  m_b1 = bet1 * m_b1 + (1 - bet1) * db1;  v_b1 = bet2 * v_b1 + (1 - bet2) * (db1 .^ 2);
  beta1 = beta1 - eta_t * ((m_b1 / (1 - bet1 ^ step)) ./ (sqrt(v_b1 / (1 - bet2 ^ step)) + eps_a));
  m_g2 = bet1 * m_g2 + (1 - bet1) * dg2;  v_g2 = bet2 * v_g2 + (1 - bet2) * (dg2 .^ 2);
  gamma2 = gamma2 - eta_t * ((m_g2 / (1 - bet1 ^ step)) ./ (sqrt(v_g2 / (1 - bet2 ^ step)) + eps_a));
  m_b2 = bet1 * m_b2 + (1 - bet1) * db2;  v_b2 = bet2 * v_b2 + (1 - bet2) * (db2 .^ 2);
  beta2 = beta2 - eta_t * ((m_b2 / (1 - bet1 ^ step)) ./ (sqrt(v_b2 / (1 - bet2 ^ step)) + eps_a));
  m_Wq = bet1 * m_Wq + (1 - bet1) * dWq;  v_Wq = bet2 * v_Wq + (1 - bet2) * (dWq .^ 2);
  Wq = Wq - eta_t * ((m_Wq / (1 - bet1 ^ step)) ./ (sqrt(v_Wq / (1 - bet2 ^ step)) + eps_a));
  m_Wk = bet1 * m_Wk + (1 - bet1) * dWk;  v_Wk = bet2 * v_Wk + (1 - bet2) * (dWk .^ 2);
  Wk = Wk - eta_t * ((m_Wk / (1 - bet1 ^ step)) ./ (sqrt(v_Wk / (1 - bet2 ^ step)) + eps_a));
  m_Wv = bet1 * m_Wv + (1 - bet1) * dWv;  v_Wv = bet2 * v_Wv + (1 - bet2) * (dWv .^ 2);
  Wv = Wv - eta_t * ((m_Wv / (1 - bet1 ^ step)) ./ (sqrt(v_Wv / (1 - bet2 ^ step)) + eps_a));
  m_Wo = bet1 * m_Wo + (1 - bet1) * dWo;  v_Wo = bet2 * v_Wo + (1 - bet2) * (dWo .^ 2);
  Wo = Wo - eta_t * ((m_Wo / (1 - bet1 ^ step)) ./ (sqrt(v_Wo / (1 - bet2 ^ step)) + eps_a));
  m_W1 = bet1 * m_W1 + (1 - bet1) * dW1;  v_W1 = bet2 * v_W1 + (1 - bet2) * (dW1 .^ 2);
  W1 = W1 - eta_t * ((m_W1 / (1 - bet1 ^ step)) ./ (sqrt(v_W1 / (1 - bet2 ^ step)) + eps_a));
  m_b1f = bet1 * m_b1f + (1 - bet1) * db1f_g;  v_b1f = bet2 * v_b1f + (1 - bet2) * (db1f_g .^ 2);
  b1f = b1f - eta_t * ((m_b1f / (1 - bet1 ^ step)) ./ (sqrt(v_b1f / (1 - bet2 ^ step)) + eps_a));
  m_W2 = bet1 * m_W2 + (1 - bet1) * dW2;  v_W2 = bet2 * v_W2 + (1 - bet2) * (dW2 .^ 2);
  W2 = W2 - eta_t * ((m_W2 / (1 - bet1 ^ step)) ./ (sqrt(v_W2 / (1 - bet2 ^ step)) + eps_a));
  m_b2f = bet1 * m_b2f + (1 - bet1) * db2f_g;  v_b2f = bet2 * v_b2f + (1 - bet2) * (db2f_g .^ 2);
  b2f = b2f - eta_t * ((m_b2f / (1 - bet1 ^ step)) ./ (sqrt(v_b2f / (1 - bet2 ^ step)) + eps_a));
  m_WU = bet1 * m_WU + (1 - bet1) * dW_U;  v_WU = bet2 * v_WU + (1 - bet2) * (dW_U .^ 2);
  W_U = W_U - eta_t * ((m_WU / (1 - bet1 ^ step)) ./ (sqrt(v_WU / (1 - bet2 ^ step)) + eps_a));

  loss_curve(step + 1) = mean_loss(1, n_pairs, tokens, E, PE, gamma1, beta1, gamma2, beta2, ...
                                     Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
  ppl_curve(step + 1) = exp(loss_curve(step + 1));

  if step == 100
    E_ck1 = E; gamma1_ck1 = gamma1; beta1_ck1 = beta1; gamma2_ck1 = gamma2; beta2_ck1 = beta2;
    Wq_ck1 = Wq; Wk_ck1 = Wk; Wv_ck1 = Wv; Wo_ck1 = Wo;
    W1_ck1 = W1; b1f_ck1 = b1f; W2_ck1 = W2; b2f_ck1 = b2f; W_U_ck1 = W_U;
  elseif step == 300
    E_ck2 = E; gamma1_ck2 = gamma1; beta1_ck2 = beta1; gamma2_ck2 = gamma2; beta2_ck2 = beta2;
    Wq_ck2 = Wq; Wk_ck2 = Wk; Wv_ck2 = Wv; Wo_ck2 = Wo;
    W1_ck2 = W1; b1f_ck2 = b1f; W2_ck2 = W2; b2f_ck2 = b2f; W_U_ck2 = W_U;
  elseif step == 600
    E_ck3 = E; gamma1_ck3 = gamma1; beta1_ck3 = beta1; gamma2_ck3 = gamma2; beta2_ck3 = beta2;
    Wq_ck3 = Wq; Wk_ck3 = Wk; Wv_ck3 = Wv; Wo_ck3 = Wo;
    W1_ck3 = W1; b1f_ck3 = b1f; W2_ck3 = W2; b2f_ck3 = b2f; W_U_ck3 = W_U;
  end
end
print("Final L =", loss_curve(n_train + 1), "  PPL =", ppl_curve(n_train + 1));
print("(For reference: a bigram-only embedding+head model on this corpus");
print(" floors at PPL ~ 1.5 — bigram has 50/50 ambiguity after 'the '.");
print(" The full transformer uses attention to resolve that ambiguity.)");

# === 8. Generation (Lesson 21).  Each step runs a full forward pass on
# === the growing prefix — no KV cache here for capstone simplicity.
# === The KV-cache version is the kv_cache.rlab demo from Lesson 21. ===
function p = next_dist(prefix, E, PE, gamma1, beta1, gamma2, beta2, ...
                       Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U)
  T = length(prefix);
  zero_mask = zeros(T - 1);
  [logits, lo, ca] = forward(prefix, zero_mask, E, PE, gamma1, beta1, gamma2, beta2, ...
                              Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
  p = softmax(logits(T, :));
end

function seq = greedy_gen(x0, n_new, E, PE, gamma1, beta1, gamma2, beta2, ...
                          Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U)
  seq = zeros(n_new + 1);
  seq(1) = x0;
  for t = 1:n_new
    prefix = seq(1:t);
    p = next_dist(prefix, E, PE, gamma1, beta1, gamma2, beta2, ...
                   Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
    seq(t + 1) = argmax(p);
  end
end

function tok = sample_categorical(p)
  c = cumsum(p);
  r = rand();
  N = length(p);
  i = 1;
  while i < N && c(i) < r
    i = i + 1;
  end
  tok = i;
end

function seq = temp_gen(x0, n_new, T_temp, E, PE, gamma1, beta1, gamma2, beta2, ...
                        Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U)
  seq = zeros(n_new + 1);
  seq(1) = x0;
  for t = 1:n_new
    prefix = seq(1:t);
    T_pref = length(prefix);
    zero_mask = zeros(T_pref - 1);
    [logits, lo, ca] = forward(prefix, zero_mask, E, PE, gamma1, beta1, gamma2, beta2, ...
                                Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
    p = softmax(logits(T_pref, :) / T_temp);
    seq(t + 1) = sample_categorical(p);
  end
end

function q = topk_mass(p, K_top)
  K = length(p);
  [s_asc, idx_asc] = sort(p);
  desc_idx = idx_asc(K:-1:1);
  keep = desc_idx(1:K_top);
  q = zeros(K);  mass = 0.0;
  for j = 1:K_top
    mass = mass + p(keep(j));
  end
  for j = 1:K_top
    q(keep(j)) = p(keep(j)) / mass;
  end
end

function seq = topk_gen(x0, n_new, K_top, T_temp, E, PE, gamma1, beta1, gamma2, beta2, ...
                        Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U)
  seq = zeros(n_new + 1);
  seq(1) = x0;
  for t = 1:n_new
    prefix = seq(1:t);
    T_pref = length(prefix);
    zero_mask = zeros(T_pref - 1);
    [logits, lo, ca] = forward(prefix, zero_mask, E, PE, gamma1, beta1, gamma2, beta2, ...
                                Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
    p = softmax(logits(T_pref, :) / T_temp);
    q = topk_mass(p, K_top);
    seq(t + 1) = sample_categorical(q);
  end
end

function q = topp_mass(p, P)
  K = length(p);
  [s_asc, idx_asc] = sort(p);
  desc_idx = idx_asc(K:-1:1);
  desc_p   = s_asc(K:-1:1);
  c = cumsum(desc_p);
  j = 1;
  while j < K && c(j) < P
    j = j + 1;
  end
  n_keep = j;
  q = zeros(K);  mass = c(n_keep);
  for j = 1:n_keep
    q(desc_idx(j)) = desc_p(j) / mass;
  end
end

function seq = topp_gen(x0, n_new, P_top, T_temp, E, PE, gamma1, beta1, gamma2, beta2, ...
                        Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U)
  seq = zeros(n_new + 1);
  seq(1) = x0;
  for t = 1:n_new
    prefix = seq(1:t);
    T_pref = length(prefix);
    zero_mask = zeros(T_pref - 1);
    [logits, lo, ca] = forward(prefix, zero_mask, E, PE, gamma1, beta1, gamma2, beta2, ...
                                Wq, Wk, Wv, Wo, W1, b1f, W2, b2f, W_U);
    p = softmax(logits(T_pref, :) / T_temp);
    q = topp_mass(p, P_top);
    seq(t + 1) = sample_categorical(q);
  end
end

# === 9. Checkpoint gallery ===
[lp, rp] = compute_merge_table(char_seq, n_base_chars, n_merges);
# The natural corpus start: every phrase of the tokenised sequence begins
# with token 17 = "the c".  Starting from anywhere else is technically
# out-of-distribution — every space char in the corpus was absorbed into
# a multi-char BPE token, so the bare space token (id 1) never appears as
# an input during training.
prompt_id = 17;
n_gen = 16;

print("");
print("=== Checkpoint gallery (16 tokens from prompt token 17 = 'the c') ===");
print("step   0 greedy : '", decode_seq(greedy_gen(prompt_id, n_gen, E_ck0, PE, gamma1_ck0, beta1_ck0, gamma2_ck0, beta2_ck0, ...
                                                     Wq_ck0, Wk_ck0, Wv_ck0, Wo_ck0, W1_ck0, b1f_ck0, W2_ck0, b2f_ck0, W_U_ck0), lp, rp, char_names), "'");
print("step 100 greedy : '", decode_seq(greedy_gen(prompt_id, n_gen, E_ck1, PE, gamma1_ck1, beta1_ck1, gamma2_ck1, beta2_ck1, ...
                                                     Wq_ck1, Wk_ck1, Wv_ck1, Wo_ck1, W1_ck1, b1f_ck1, W2_ck1, b2f_ck1, W_U_ck1), lp, rp, char_names), "'");
print("step 300 greedy : '", decode_seq(greedy_gen(prompt_id, n_gen, E_ck2, PE, gamma1_ck2, beta1_ck2, gamma2_ck2, beta2_ck2, ...
                                                     Wq_ck2, Wk_ck2, Wv_ck2, Wo_ck2, W1_ck2, b1f_ck2, W2_ck2, b2f_ck2, W_U_ck2), lp, rp, char_names), "'");
print("step 600 greedy : '", decode_seq(greedy_gen(prompt_id, n_gen, E_ck3, PE, gamma1_ck3, beta1_ck3, gamma2_ck3, beta2_ck3, ...
                                                     Wq_ck3, Wk_ck3, Wv_ck3, Wo_ck3, W1_ck3, b1f_ck3, W2_ck3, b2f_ck3, W_U_ck3), lp, rp, char_names), "'");

seed(101);
print("step 600 T=0.7  : '", decode_seq(temp_gen(prompt_id, n_gen, 0.7, E_ck3, PE, gamma1_ck3, beta1_ck3, gamma2_ck3, beta2_ck3, ...
                                                   Wq_ck3, Wk_ck3, Wv_ck3, Wo_ck3, W1_ck3, b1f_ck3, W2_ck3, b2f_ck3, W_U_ck3), lp, rp, char_names), "'");
print("step 600 T=1.0  : '", decode_seq(temp_gen(prompt_id, n_gen, 1.0, E_ck3, PE, gamma1_ck3, beta1_ck3, gamma2_ck3, beta2_ck3, ...
                                                   Wq_ck3, Wk_ck3, Wv_ck3, Wo_ck3, W1_ck3, b1f_ck3, W2_ck3, b2f_ck3, W_U_ck3), lp, rp, char_names), "'");
print("step 600 K=3    : '", decode_seq(topk_gen(prompt_id, n_gen, 3, 1.0, E_ck3, PE, gamma1_ck3, beta1_ck3, gamma2_ck3, beta2_ck3, ...
                                                   Wq_ck3, Wk_ck3, Wv_ck3, Wo_ck3, W1_ck3, b1f_ck3, W2_ck3, b2f_ck3, W_U_ck3), lp, rp, char_names), "'");
print("step 600 P=0.9  : '", decode_seq(topp_gen(prompt_id, n_gen, 0.9, 1.0, E_ck3, PE, gamma1_ck3, beta1_ck3, gamma2_ck3, beta2_ck3, ...
                                                   Wq_ck3, Wk_ck3, Wv_ck3, Wo_ck3, W1_ck3, b1f_ck3, W2_ck3, b2f_ck3, W_U_ck3), lp, rp, char_names), "'");

# === 10. Diagnostic plots ===
steps_axis = 0:n_train;
figure()
subplot(2, 2, 1)
plot(steps_axis, loss_curve, "color", "red")
title("Loss vs step (full transformer, nats)")
xlabel("step"); ylabel("L")
subplot(2, 2, 2)
plot(steps_axis, ppl_curve, "color", "blue")
title("PPL vs step (PPL = 1 is perfect)")
xlabel("step"); ylabel("PPL")
subplot(2, 2, 3)
plot(steps_axis, log10(gnorm + 1e-12), "color", "green")
title("log10 || grad || over training")
xlabel("step"); ylabel("log10 ||grad||")
subplot(2, 2, 4)
plot(steps_axis, lr_curve, "color", "purple")
title("Learning-rate schedule (warmup + cosine)")
xlabel("step"); ylabel("eta")
savefig("capstone.svg")
print("");
print("Saved capstone.svg");
